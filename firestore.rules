rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: products
    // Fields: name, price, stock, category, etc.
    //
    // Collection: sales
    // Fields: customerName, customerPhone, items, total, status, date, etc.
    //
    // Collection: customers
    // Fields: name, totalDue, lastUpdate
    //
    // Collection: users
    // Fields: name, phone, role, password, etc.
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         request.auth.token.email == "jummanbepari5@gmail.com");
    }

    function isValidSale(data) {
      return data.items is list && data.items.size() > 0 &&
             data.total is number && data.total >= 0 &&
             data.status in ['Pending', 'Delivered', 'Cancelled'] &&
             data.date is string;
    }

    function isValidCustomer(data) {
      return data.name is string && data.name.size() > 0 &&
             data.totalDue is number;
    }

    // Rules
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /sales/{saleId} {
      allow create: if true; // Allow anyone to place an order
      allow read, update, delete: if isAuthenticated();
    }

    match /customers/{phone} {
      allow read: if true;
      allow write: if true; // Allow updating dues during sale
    }

    match /users/{phone} {
      allow read: if true;
      allow write: if true; // Allow registration
    }

    match /{path=**} {
      allow read, write: if isAuthenticated();
    }
  }
}
